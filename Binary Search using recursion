#include <iostream>
using namespace std;

int binary(int a[],int l,int r,int x){
    if(l<=r){
        int mid=(l+r)/2;

        if(a[mid]==x)
            return mid;
        else if(x<a[mid])
            return binary(a,l,mid-1,x);
        else
            return binary(a,mid+1,r,x);
    }
    return -1;
}

int main(){
    int a[]={1,2,3,4,5};
    cout<<binary(a,0,4,4);
}
